# Copy this file to `.env` and edit as needed. Everything below is optional —
# with nothing set, the extension behaves exactly as it does out of the box.

# ----- Dev tooling (Node-only, read by web-ext.config.ts) -----
# Deliberately unprefixed: these configure `wxt dev`'s browser launch, not the
# extension itself, so they must NOT be exposed to the shipped bundle.

# Path to a Chromium-based browser binary. Needed if Google Chrome isn't on your
# PATH (e.g. you use Brave, Chromium, or Edge). Examples:
#   /usr/bin/brave   /usr/bin/chromium   /usr/bin/google-chrome
DEV_BROWSER=

# Persistent profile directory, so your Upwork login and extension settings
# survive `npm run dev` restarts instead of starting from a fresh profile.
DEV_PROFILE=

# ----- App config (baked into the bundle at build time — WXT_ prefix required) -----
# Changing these requires a rebuild (`npm run build` / restart `npm run dev`).
# Invalid values fall back to the default and log a console.warn.

# Max concurrent LLM requests the background worker runs at once.
WXT_LLM_CONCURRENCY=

# Enables the "Deep-dive full description" feature.
WXT_DEEP_DIVE_ENABLED=
