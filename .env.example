# Per-machine settings for `wxt dev` — copy this file to `.env` and edit.
# Both are optional; with neither set, `wxt dev` auto-detects Chrome/Chromium
# and uses a throwaway profile.

# Path to a Chromium-based browser binary. Needed if Google Chrome isn't on your
# PATH (e.g. you use Brave, Chromium, or Edge). Examples:
#   /usr/bin/brave   /usr/bin/chromium   /usr/bin/google-chrome
SIFT_DEV_BROWSER=

# Persistent profile directory, so your Upwork login and extension settings
# survive `npm run dev` restarts instead of starting from a fresh profile.
SIFT_DEV_PROFILE=
